# ─── Database (SQL Server 2022) ───────────────────────────────────────────────
# Production / Heroku MSSQL addon or Azure SQL
DATABASE_URL="sqlserver://HOST:1433;database=kite_hub;user=sa;password=YourPassword;encrypt=true;trustServerCertificate=false"

# Local development (SQL Server 2022 on localhost)
# DATABASE_URL="sqlserver://localhost:1433;database=kite_hub;user=SA;password=YourStrong!Pass;encrypt=true;trustServerCertificate=true"

# SQL Server Express (instancia SQLEXPRESS): en una URL no uses \ literal; codifícala
# como %5C. Ejemplo equivalente a localhost\SQLEXPRESS (sin :puerto en el host):
# DATABASE_URL="sqlserver://localhost%5CSQLEXPRESS;database=kite_hub;user=SA;password=YourStrong!Pass;encrypt=true;trustServerCertificate=true"
# NUNCA mezcles instancia + puerto: mal → localhost%5CSQLEXPRESS:1433
# Si habilitaste TCP con puerto fijo, usa solo host:puerto (sin %5CSQLEXPRESS):
# DATABASE_URL="sqlserver://localhost:1433;database=kite_hub;user=SA;password=YourStrong!Pass;encrypt=true;trustServerCertificate=true"

# ─── Dev Auth Bypass (development only) ───────────────────────────────────────
# Set DEV_AUTH_BYPASS=true to skip Auth0 entirely and log in as a hardcoded
# admin user (dev|bypass-admin). Only active when NODE_ENV=development.
#
# ⛔ NEVER set this to true in production or staging.
#    Setting it outside of NODE_ENV=development throws a startup error.
#    Run `npm run check:no-bypass-prod` before every release to verify.
DEV_AUTH_BYPASS="true"

# Force UI to skip Prisma in development (zeros/empty lists). Optional; without
# it, dev auth bypass still falls back when the DB is unreachable or credentials fail.
# DEV_SKIP_DB="true"

# ─── Auth0 ────────────────────────────────────────────────────────────────────
# SDK reads these env vars automatically via Auth0Client().
# When DEV_AUTH_BYPASS=true these values are never used — placeholder strings
# are enough to prevent any accidental import from crashing.
AUTH0_SECRET="use [openssl rand -hex 32] to generate a 32 bytes value"
AUTH0_BASE_URL="https://your-app.herokuapp.com"
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID="YOUR_AUTH0_CLIENT_ID"
AUTH0_CLIENT_SECRET="YOUR_AUTH0_CLIENT_SECRET"

# ─── Kiosk security ───────────────────────────────────────────────────────────
# Secret expected by POST /api/kiosk/loan-or-return in header x-kiosk-key
# Generate: openssl rand -hex 32
KIOSK_SECRET="a58f027f89f385043fd33b5638bc1d54768662eb44557d40b40687ba753d0a80"
# Public key used by src/components/kiosk/KioskScanner.tsx.
# Must match KIOSK_SECRET in development kiosk tests.
NEXT_PUBLIC_KIOSK_KEY="a58f027f89f385043fd33b5638bc1d54768662eb44557d40b40687ba753d0a80"

# ─── Jobs security ────────────────────────────────────────────────────────────
# Bearer token required by POST /api/jobs/overdue
# Generate: openssl rand -hex 32  (use a DIFFERENT value from KIOSK_SECRET)
CRON_SECRET="generate-a-strong-random-secret"

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Kite Hub <noreply@yourdomain.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
